PORT=4000
MQTT_PORT=1883

# URL of the frontend — used to restrict CORS
CLIENT_URL=http://localhost:5173

# Optional: get a free key at https://openweathermap.org/api
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Lagos

# Firebase service account JSON (minified, single line).
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then paste the entire JSON on one line below.
# Leave blank in dev — routes will be unprotected but functional.
FIREBASE_SERVICE_ACCOUNT=
